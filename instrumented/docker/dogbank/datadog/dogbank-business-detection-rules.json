[
  {
    "name": "[DogBank] Successful SQL Injection - PIX key validation data leak",
    "enabled": true,
    "product": "App & API Protection",
    "type": "application_security",
    "detection_method": "threshold",
    "queries": [
      {
        "name": "sqli_success",
        "query": "service:transaction-service @appsec.type:sql_injection @http.status_code:200 @http.url:*api/transactions/validate-pix-key*",
        "aggregation": "count",
        "groupByFields": ["@network.client.ip"]
      }
    ],
    "cases": [
      {
        "name": "CRITICAL - SQLi returned HTTP 200 on data-leak endpoint",
        "status": "critical",
        "condition": "sqli_success > 0"
      }
    ],
    "options": {
      "evaluationWindow": 300,
      "keepAlive": 3600,
      "maxSignalDuration": 86400
    },
    "message": "SQL Injection bem-sucedido no DogBank. O mesmo request foi classificado como SQLi e retornou HTTP 200 no endpoint /api/transactions/validate-pix-key, que pode vazar nome, CPF, saldo e chave PIX. Verificar trace, payload e arquivo de provas do EvilDog.",
    "tags": [
      "env:dogbank",
      "service:transaction-service",
      "attack:sql-injection",
      "impact:data-exfiltration",
      "cwe:89",
      "team:security-demo"
    ]
  },
  {
    "name": "[DogBank] Successful SQL Injection - records leaked in application logs",
    "enabled": true,
    "product": "Cloud SIEM",
    "type": "log_detection",
    "detection_method": "threshold",
    "queries": [
      {
        "name": "leak_logs",
        "query": "service:transaction-service (\"SQL INJECTION DETECTADO\" OR \"records_leaked\" OR @security_event:sql_injection_vulnerable_endpoint)",
        "aggregation": "count",
        "groupByFields": ["@network.client.ip"]
      }
    ],
    "cases": [
      {
        "name": "CRITICAL - Backend confirmed SQLi data exposure",
        "status": "critical",
        "condition": "leak_logs > 0"
      }
    ],
    "options": {
      "evaluationWindow": 300,
      "keepAlive": 3600,
      "maxSignalDuration": 86400
    },
    "message": "O backend registrou SQL Injection com vazamento de registros. Esta regra complementa o App & API Protection usando logs da aplicação para marcar a exploração como bem-sucedida.",
    "tags": [
      "env:dogbank",
      "service:transaction-service",
      "attack:sql-injection",
      "impact:data-exfiltration",
      "source:logs",
      "team:security-demo"
